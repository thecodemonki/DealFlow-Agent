# Register each agent in Band (band.ai/agents → New Agent → External Agent)
# Then paste the agent_id and api_key for each below.
# Copy this file to agent_config.yaml and fill in real values.

orchestrator:
  agent_id: 
  api_key: "replace-with-orchestrator-api-key"

